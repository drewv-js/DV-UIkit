{
  "name": "@dv-uikit/web-components",
  "version": "0.1.0",
  "description": "Private reusable Web Component kit with Tailwind-based design tokens and React wrappers.",
  "type": "module",
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "sideEffects": [
    "./dist/auto-register.js",
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "tailwind.preset.cjs",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./auto-register": {
      "types": "./dist/auto-register.d.ts",
      "import": "./dist/auto-register.js",
      "default": "./dist/auto-register.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": "./tailwind.preset.cjs"
  },
  "scripts": {
    "clean": "node -e \"const fs=require(\\\"node:fs\\\"); fs.rmSync(\\\"dist\\\",{recursive:true,force:true}); fs.rmSync(\\\"coverage\\\",{recursive:true,force:true});\"",
    "build": "npm run clean && npm run build:styles && npm run build:stencil && npm run build:auto-register && npm run build:react && npm run build:react:types",
    "build:styles": "tailwindcss -c tailwind.config.cjs -i ./src/styles/tailwind.css -o ./dist/styles.css --minify",
    "build:stencil": "stencil build",
    "build:auto-register": "node ./scripts/write-auto-register.mjs",
    "build:react": "esbuild src/react.ts --bundle --format=esm --platform=browser --outfile=dist/react.js --external:react --external:react-dom --external:react/jsx-runtime",
    "build:react:types": "tsc -p tsconfig.react.types.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "component:new": "node ./scripts/new-component.mjs",
    "component:check": "node ./scripts/validate-components.mjs",
    "storybook:prepare": "npm run build:styles && npm run build:stencil",
    "storybook": "npm run storybook:prepare && storybook dev -p 6006",
    "storybook:build": "npm run storybook:prepare && storybook build",
    "test": "stencil test --spec",
    "audit": "npm audit --omit=dev",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release:verify": "npm run component:check && npm run lint && npm run test && npm run build",
    "release:patch": "npm run release:verify && npm version patch",
    "release:minor": "npm run release:verify && npm version minor",
    "release:major": "npm run release:verify && npm version major"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewv-js/DV-UIkit.git"
  },
  "keywords": [
    "web-components",
    "stencil",
    "tailwind",
    "design-system",
    "react-wrapper"
  ],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/drewv-js/DV-UIkit/issues"
  },
  "homepage": "https://github.com/drewv-js/DV-UIkit#readme",
  "collection": "./dist/collection/collection-manifest.json",
  "publishConfig": {
    "access": "restricted",
    "provenance": true
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@stencil/core": "^4.38.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/web-components-vite": "^10.4.6",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^4.0.1",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
